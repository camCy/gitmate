{
  "name": "gitmate",
  "version": "0.1.0",
  "description": "Generador de mensajes de commit con IA usando Groq",
  "main": "dist/cli.js",
  "bin": {
    "gitmate": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsc && node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["git", "commit", "ai", "groq"],
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "groq-sdk": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5"
  }
}